{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.13.7/.schema/devbox.schema.json",
  "packages": [
    "dart-sass@latest",
    "python312@latest",
    "pre-commit@latest",
    "nodejs@latest",
    "nodePackages.prettier@latest",
    "nodePackages.stylelint@latest",
    "yamllint@latest"
  ],
  "shell": {
    "init_hook": [
      "pre-commit install --install-hooks 2>/dev/null || true"
    ]
  }
}
